<?xml version="1.0" encoding="utf-8"?>
<!DOCTYPE FBType SYSTEM "../LibraryElement.dtd">
<FBType GUID="8d456825-c698-4103-a438-84e6c9b4b1d1" Name="Station_Status" Comment="Basic Function Block Type" Namespace="Main">
  <Identification Standard="61499-2" />
  <VersionInfo Organization="Schneider Electric" Version="0.0" Author="Evans_A" Date="7/18/2025" Remarks="Template" />
  <InterfaceList>
    <EventInputs>
      <Event Name="INIT" Comment="Initialization Request">
        <With Var="LLMode" />
        <With Var="LLCycleType" />
        <With Var="LocalMode" />
        <With Var="LocalCycleType" />
      </Event>
      <Event Name="LLM" Comment="Normal Execution Request">
        <With Var="LLMode" />
      </Event>
      <Event Name="LLCT">
        <With Var="LLCycleType" />
      </Event>
      <Event Name="MREQ">
        <With Var="LocalMode" />
      </Event>
      <Event Name="CTREQ">
        <With Var="LocalCycleType" />
      </Event>
    </EventInputs>
    <EventOutputs>
      <Event Name="INITO" Comment="Initialization Confirm">
        <With Var="SystemModeStatus" />
        <With Var="SystemCycleTypeStatus" />
      </Event>
      <Event Name="MCNF" Comment="Execution Confirmation">
        <With Var="SystemModeStatus" />
      </Event>
      <Event Name="CTCNF">
        <With Var="SystemCycleTypeStatus" />
      </Event>
    </EventOutputs>
    <InputVars>
      <VarDeclaration Name="LLMode" Type="INT" Comment="Input event qualifier" />
      <VarDeclaration Name="LLCycleType" Type="INT" />
      <VarDeclaration Name="LocalMode" Type="INT" />
      <VarDeclaration Name="LocalCycleType" Type="INT" />
    </InputVars>
    <OutputVars>
      <VarDeclaration Name="SystemModeStatus" Type="INT" Comment="Output event qualifier" />
      <VarDeclaration Name="SystemCycleTypeStatus" Type="INT" />
    </OutputVars>
  </InterfaceList>
  <BasicFB>
    <Attribute Name="FBType.Basic.Algorithm.Order" Value="INIT,Mode,CycleType" />
    <ECC>
      <ECState Name="START" Comment="Initial State" x="704.9412" y="401.4117" />
      <ECState Name="INIT" Comment="Initialization" x="695.5294" y="105.1765">
        <ECAction Algorithm="INIT" Output="INITO" />
      </ECState>
      <ECState Name="MODE" Comment="Normal execution" x="217.647" y="752.9412">
        <ECAction Algorithm="Mode" Output="MCNF" />
      </ECState>
      <ECState Name="CYCLETYPE" x="1232" y="744">
        <ECAction Algorithm="CycleType" Output="CTCNF" />
      </ECState>
      <ECTransition Source="START" Destination="INIT" Condition="INIT" x="700.3466" y="334.8169">
        <Attribute Name="Configuration.Transaction.BezierPoints" Value="175.3128,96.31814,174.8048,80.32892" />
      </ECTransition>
      <ECTransition Source="INIT" Destination="START" Condition="1" x="786.4442" y="250.9124">
        <Attribute Name="Configuration.Transaction.BezierPoints" Value="199.7922,54.53503,200.3002,70.52425" />
      </ECTransition>
      <ECTransition Source="START" Destination="MODE" Condition="MREQ OR LLM" x="516.5503" y="641.1965">
        <Attribute Name="Configuration.Transaction.BezierPoints" Value="144.2257,154.2706,115.6738,174.8676" />
      </ECTransition>
      <ECTransition Source="MODE" Destination="START" Condition="1" x="450.3054" y="498.6516">
        <Attribute Name="Configuration.Transaction.BezierPoints" Value="101.0476,129.5927,129.5995,108.9956" />
      </ECTransition>
      <ECTransition Source="START" Destination="CYCLETYPE" Condition="CTREQ OR LLCT" x="1031.509" y="509.4368">
        <Attribute Name="Configuration.Transaction.BezierPoints" Value="245.0888,113.7972,273.2213,132.6192" />
      </ECTransition>
      <ECTransition Source="CYCLETYPE" Destination="START" Condition="1" x="889.2453" y="636.2498">
        <Attribute Name="Configuration.Transaction.BezierPoints" Value="234.775,172.7628,210.6037,154.6257" />
      </ECTransition>
    </ECC>
    <Algorithm Name="INIT" Comment="Initialization algorithm">
      <ST><![CDATA[;]]></ST>
    </Algorithm>
    <Algorithm Name="Mode" Comment="Normally executed algorithm">
      <ST><![CDATA[IF LLMode = LocalMode THEN
	SystemModeStatus := LocalMode;
ELSE
	SystemModeStatus := 100;
END_IF;
]]></ST>
    </Algorithm>
    <Algorithm Name="CycleType">
      <ST><![CDATA[IF LLCycleType = LocalCycleType THEN
	SystemCycleTypeStatus := LocalCycleType;
ELSE
	SystemCycleTypeStatus := 100;
END_IF;
]]></ST>
    </Algorithm>
  </BasicFB>
</FBType>